#: utils/formatting.cpp
#, kde-format
msgctxt "1 is a date"
msgid ""
"Signature created on %1 using an unknown certificate with fingerprint %2"
msgstr ""
"Podpis, ustvarjen na %1 uporablja neznano potrdilo s prstnim odtisom %2"

#: utils/formatting.cpp
#, kde-format
msgid "Signature created using an unknown certificate with fingerprint %1"
msgstr "Podpis ustvarjen z uporabo neznanega potrdila s prstnim odtisom %1"

#: utils/formatting.cpp
#, kde-format
msgctxt "1 is a date"
msgid "Signature created on %1 with certificate: %2"
msgstr "Podpis, ustvarjen na %1 s potrdilom: %2"

#: utils/formatting.cpp
#, kde-format
msgid "Signature created with certificate: %1"
msgstr "Podpis ustvarjen s potrdilom: %1"

#: utils/formatting.cpp
#, kde-format
msgctxt ""
"%1 is a placeholder for the name of a compliance mode. E.g. NATO RESTRICTED "
"compliant or VS-NfD compliant"
msgid "The signature is %1"
msgstr "Podpis je %1"

#: utils/formatting.cpp
#, kde-format
msgctxt ""
"%1 is a placeholder for the name of a compliance mode. E.g. NATO RESTRICTED "
"compliant or VS-NfD compliant"
msgid "The signature <b>is not</b> %1."
msgstr "Podpis <b>ni</b> %1."

#: utils/formatting.cpp
#, kde-format
msgid "Error: Signature not verified"
msgstr "Napaka: Podpis ni preverjen"

#: utils/formatting.cpp
#, kde-format
msgid "Good signature"
msgstr "Dober podpis"

#: utils/formatting.cpp
#, kde-format
msgid "Signing certificate was revoked"
msgstr "Podpisno potrdilo je bilo preklicano"

#: utils/formatting.cpp
#, kde-format
msgid "Signing certificate is expired"
msgstr "Podpisno potrdilo je poteklo"

#: utils/formatting.cpp
#, kde-format
msgid "Certificate is not available"
msgstr "Potrdilo ni na voljo"

#: utils/formatting.cpp
#, kde-format
msgid "Signature expired"
msgstr "Podpis je potekel"

#: utils/formatting.cpp
#, kde-format
msgid "CRL missing"
msgstr "CRL manjka"

#: utils/formatting.cpp
#, kde-format
msgid "CRL too old"
msgstr "CRL je prestar"

#: utils/formatting.cpp
#, kde-format
msgid "Bad policy"
msgstr "Slaba politika"

#: utils/formatting.cpp
#, kde-format
msgid "System error"
msgstr "Sistemska napaka"

#: utils/formatting.cpp
#, kde-format
msgid "Bad signature"
msgstr "Slab podpis"

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgid "The signature is invalid: %1"
msgstr "Podpis je neveljaven: %1"

#: utils/formatting.cpp
#, kde-format
msgid "You can search the certificate on a keyserver or import it from a file."
msgstr "Potrdilo lahko iščete na strežniku ključev ali ga uvozite iz datoteke."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used key is not certified by you or any "
"trusted person."
msgstr ""
"Podpis je veljaven, vendar uporabljenega ključa niste potrdili vi ali katera "
"koli druga zaupanja vredna oseba."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used certificate is not certified by a "
"trustworthy Certificate Authority or the Certificate Authority is unknown."
msgstr ""
"Podpis je veljaven, vendar uporabljeno potrdilo ni overjeno s strani "
"zaupanja vrednega overitelja potrdil ali pa je overitelj potrdil neznan."

#: utils/formatting.cpp utils/formatting.cpp
#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> There is no indication that the signature belongs "
"to the owner."
msgstr ""
"<strong>Opozorilo:</strong> Ni nobenih znakov, da to potrdilo pripada temu "
"prejemniku."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> It is not certain that the signature belongs to "
"the owner."
msgstr "<strong>Opozorilo:</strong> Ni gotovo, da podpis pripada lastniku."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but it has expired."
msgstr "Podpis je veljaven, a je potekel."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but it has expired and the used key is not certified "
"by you or any trusted person."
msgstr ""
"Podpis je veljaven, a je potekel in uporabljenega ključa niste potrdili vi "
"ali katera koli druga zaupanja vredna oseba."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has expired."
msgstr "Podpis je veljaven, a je uporabljeni ključ potekel."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has been revoked."
msgstr "Podpis je veljaven, a je bil uporabljeni ključ preklican."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "<strong>Warning:</strong> This could mean that the signature is forged."
msgstr "<strong>Opozorilo:</strong> To lahko pomeni, da je podpis ponarejen."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The used key is not certified by you or any trusted person."
msgstr ""
"Uporabljenega ključa niste potrdili vi ali katera koli druga zaupanja vredna "
"oseba."

#: utils/gnupg.cpp
