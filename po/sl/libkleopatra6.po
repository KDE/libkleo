msgid ""
"Enter your LDAP user resp. Bind DN for authenticating to the LDAP server."
msgstr ""
"Vnesite vašega uporabnika LDAP. Povežite DN za overjanje na strežnik LDAP."

#: ui/editdirectoryservicedialog.cpp
#, kde-format
msgid "Password:"
msgstr "Geslo:"

