msgid "Authenticate to the LDAP server with your LDAP credentials."
msgstr "Overite se na strežniku LDAP z vašimi poverilnicami LDAP."

#: ui/editdirectoryservicedialog.cpp
#, kde-format
msgid "User:"
msgstr "Uporabnik:"

#: ui/editdirectoryservicedialog.cpp
#, kde-format
