#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used key is not certified by you or any "
"trusted person."
msgstr ""
"A assinatura é válida mas a chave usada não foi certificada por você ou por "
"qualquer pessoa confiável."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used certificate is not certified by a "
"trustworthy Certificate Authority or the Certificate Authority is unknown."
msgstr ""
"A assinatura é válida mas o certificado usado não foi certificado por uma "
"Autoridade Certificadora confiável ou a Autoridade Certificadora é "
"desconhecida."

#: utils/formatting.cpp utils/formatting.cpp
#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> There is no indication that the signature belongs "
"to the owner."
msgstr ""
"<strong>Aviso:</strong> Não há indicação de que a assinatura pertença ao "
"proprietário."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> It is not certain that the signature belongs to "
"the owner."
msgstr ""
"<strong>Aviso:</strong> Não há certeza de que a assinatura pertença ao "
"proprietário."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but it has expired."
msgstr "A assinatura é válida, mas expirou."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but it has expired and the used key is not certified "
"by you or any trusted person."
msgstr ""
"A assinatura é válida, mas expirou e a chave usada não foi certificada por "
"você ou por qualquer pessoa de confiança."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has expired."
msgstr "A assinatura é válida, mas a chave utilizada expirou."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has been revoked."
msgstr "A assinatura é válida, mas a chave utilizada foi revogada."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "<strong>Warning:</strong> This could mean that the signature is forged."
msgstr ""
"<strong>Aviso:</strong> Isso pode significar que a assinatura foi "
"falsificada."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The used key is not certified by you or any trusted person."
msgstr ""
"A chave usada não foi certificada por você ou por qualquer pessoa confiável."

