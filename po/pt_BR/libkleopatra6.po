#: ui/newkeyapprovaldialog.cpp
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Signing your message provides cryptographic confirmation that you really are "
"the sender of this message."
msgstr ""
"Assinar sua mensagem fornece confirmação criptográfica de que você é "
"realmente o remetente desta mensagem."

#: ui/newkeyapprovaldialog.cpp
#, kde-format
msgid "No key. Recipient will be unable to decrypt."
msgstr "Sem chave. O destinatário não irá conseguir descriptografar."

