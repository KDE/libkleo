#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used key is not certified by you or any "
"trusted person."
msgstr ""
"Подпись действительна, но использованный для её создания ключ не удостоверен "
"вами или каким-либо доверенным лицом."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used certificate is not certified by a "
"trustworthy Certificate Authority or the Certificate Authority is unknown."
msgstr ""
"Подпись действительна, но использованный сертификат не удостоверен "
"доверенным центром сертификации или центр сертификации неизвестен."

#: utils/formatting.cpp utils/formatting.cpp
#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> There is no indication that the signature belongs "
"to the owner."
msgstr ""
"<strong>Предупреждение:</strong> Отсутствуют признаки того, что подпись "
"принадлежит владельцу."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> It is not certain that the signature belongs to "
"the owner."
msgstr ""
"<strong>Предупреждение:</strong> Нет уверенности, что подпись принадлежит "
"владельцу."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but it has expired."
msgstr "Подпись действительна, но срок её действия истёк."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but it has expired and the used key is not certified "
"by you or any trusted person."
msgstr ""
"Подпись действительна, но срок её действия истёк, а использованный для её "
"создания ключ не удостоверен вами или каким-либо доверенным лицом."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has expired."
msgstr ""
"Подпись действительна, но истёк срок действия ключа, использованного для её "
"создания."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has been revoked."
msgstr ""
"Подпись действительна, ключ, использованный для её создания, был отозван."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "<strong>Warning:</strong> This could mean that the signature is forged."
msgstr ""
"<strong>Предупреждение:</strong> Это может означать, что подпись подделана."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The used key is not certified by you or any trusted person."
msgstr ""
"Использовавшийся ключ не удостоверен вами или каким-либо доверенным лицом."

