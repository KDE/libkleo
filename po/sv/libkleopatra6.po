#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used key is not certified by you or any "
"trusted person."
msgstr ""
"Signaturen är giltig men den använda nyckeln är inte certifierad av dig "
"eller någon annan pålitlig person."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used certificate is not certified by a "
"trustworthy Certificate Authority or the Certificate Authority is unknown."
msgstr ""
"Signaturen är giltig men det använda certifikatet har inte certifierats av "
"en pålitlig certifikatutfärdare, eller så är certifikatutfärdaren okänd."

#: utils/formatting.cpp utils/formatting.cpp
#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> There is no indication that the signature belongs "
"to the owner."
msgstr ""
"<strong>Varning:</strong> Det finns ingen indikering att certifikatet hör "
"till ägaren."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> It is not certain that the signature belongs to "
"the owner."
msgstr ""
"<strong>Varning:</strong> Det är inte säkert att signaturen tillhör ägaren."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but it has expired."
msgstr "Signaturen är giltig men har gått ut."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but it has expired and the used key is not certified "
"by you or any trusted person."
msgstr ""
"Signaturen är giltig men har gått ut och den använda nyckeln är inte "
"certifierad av dig eller någon annan pålitlig person."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has expired."
msgstr "Signaturen är giltig men den använda nyckeln har gått ut."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has been revoked."
msgstr "Signaturen är giltig men den använda nyckeln har återkallats."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "<strong>Warning:</strong> This could mean that the signature is forged."
msgstr ""
"<strong>Varning:</strong> Det kan innebära att signaturen är förfalskad."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The used key is not certified by you or any trusted person."
msgstr ""
"Den använda nyckeln är inte certifierad av dig eller någon annan pålitlig "
"person."

