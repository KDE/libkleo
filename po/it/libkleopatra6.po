#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used key is not certified by you or any "
"trusted person."
msgstr ""
"La firma è valida ma la chiave usata non è certificata da te o da alcuna "
"persona attendibile."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but the used certificate is not certified by a "
"trustworthy Certificate Authority or the Certificate Authority is unknown."
msgstr ""
"La firma è valida ma il certificato usato non è certificato da un'autorità "
"di certificazione attendibile o l'autorità di certificazione è sconosciuta."

#: utils/formatting.cpp utils/formatting.cpp
#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> There is no indication that the signature belongs "
"to the owner."
msgstr ""
"<strong>Attenzione:</strong> non ci sono indicazioni la firma appartenga "
"effettivamente al proprietario."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<strong>Warning:</strong> It is not certain that the signature belongs to "
"the owner."
msgstr ""
"<strong>Attenzione:</strong> non è certo c he la firma appartenga "
"effettivamente al proprietario."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but it has expired."
msgstr "La firma è valida ma è scaduta."

#: utils/formatting.cpp utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid ""
"The signature is valid but it has expired and the used key is not certified "
"by you or any trusted person."
msgstr ""
"La firma è valida ma è scaduta e la chiave usata non è certificata da te o "
"da alcuna persona attendibile."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has expired."
msgstr "La firma è valida ma la chiave usata è scaduta."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The signature is valid but the used key has been revoked."
msgstr "La firma è valida ma la chiave usata è stata revocata."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "<strong>Warning:</strong> This could mean that the signature is forged."
msgstr ""
"<strong>Attenzione:</strong> questo potrebbe voler dire che la firma è "
"contraffatta."

#: utils/formatting.cpp
#, kde-format
msgctxt "@info"
msgid "The used key is not certified by you or any trusted person."
msgstr ""
"La chiave usata non è certificata da te o da alcuna persona attendibile."

